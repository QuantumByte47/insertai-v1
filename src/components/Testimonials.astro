---
// ⚠️ PLACEHOLDER testimonials — swap for real client quotes when you have them.
const testimonials = [
  {
    quote: "Their voice agent books appointments while we sleep. We stopped missing after-hours calls completely — it paid for itself in the first month.",
    name: "Sarah Mitchell", role: "Owner, Brightside Dental", avatar: "/avatar-1.webp",
  },
  {
    quote: "We were drowning in manual QuickBooks and HubSpot entry. InsertAI automated all of it. My team got ~20 hours a week back.",
    name: "James Carter", role: "Operations Director, Carter Logistics", avatar: "/avatar-2.webp",
  },
  {
    quote: "Every lead now gets a response in seconds, not hours. Our close rate jumped and we didn't add a single hire.",
    name: "Priya Nair", role: "Founder, LeadForge Marketing", avatar: "/avatar-3.webp",
  },
];
---

<section class="hair-t">
  <div class="mx-auto max-w-[1600px] px-5 sm:px-8">
    <!-- header -->
    <div class="hair-b grid grid-cols-1 gap-4 py-12 lg:grid-cols-12">
      <p class="mono text-[--color-fg-dim] lg:col-span-3">(05) / Proof</p>
      <h2 class="display text-[clamp(2rem,5.2vw,4.75rem)] text-[--color-fg] lg:col-span-9">
        They stopped doing it <span class="stroke-type stroke-acc">manually</span>
      </h2>
    </div>

    <!-- quotes -->
    <div class="grid grid-cols-1 md:grid-cols-3">
      {testimonials.map((t) => (
        <figure class="hair-b border-[--color-line] py-10 md:px-7 md:border-b-0 md:[&:not(:first-child)]:border-l">
          <div class="mono text-[--color-acc]">★★★★★</div>
          <blockquote class="mt-5 text-lg leading-relaxed text-[--color-fg]">“{t.quote}”</blockquote>
          <figcaption class="mt-7 flex items-center gap-3">
            <img src={t.avatar} alt={t.name} width="44" height="44" loading="lazy" decoding="async"
                 class="warm-asset h-11 w-11 border border-[--color-line] object-cover" />
            <span>
              <span class="mono block text-[--color-fg]">{t.name}</span>
              <span class="mono block text-[--color-fg-dim]">{t.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
