---
import { site } from "../data/site";

const links = [
  { href: "#work", label: "Work" },
  { href: "#services", label: "Services" },
  { href: "#process", label: "Process" },
  { href: "#about", label: "About" },
  { href: "#insights", label: "Insights" },
];
---

<header class="fixed inset-x-0 top-0 z-50">
  <div class="site-shell mt-4 flex items-center justify-between rounded-full border border-white/10 bg-black/35 px-4 py-3 shadow-2xl shadow-black/30 backdrop-blur-xl sm:px-5">
    <a href="#top" class="flex items-center text-white" aria-label={site.name}>
      <img src="/insertai-logo.webp" alt={`${site.name} logo`} width="1448" height="350" class="h-7 w-auto" />
    </a>

    <nav class="hidden items-center gap-9 lg:flex">
      {links.map((l) => (
        <a href={l.href} class="text-sm text-white/78 transition hover:text-white">
          {l.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a href={site.voiceAgentPhoneHref} class="hidden h-10 w-10 place-items-center rounded-full border border-white/10 text-white/80 transition hover:border-white/30 hover:text-white sm:grid" aria-label="Call the AI agent">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6.5 4h3l1.5 4-2 1.5a12 12 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2.2 2A16 16 0 0 1 4.5 6.2 2 2 0 0 1 6.5 4Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
        </svg>
      </a>
      <a href={site.bookingUrl} class="btn-primary px-5 py-3">Let's Build <span aria-hidden="true">→</span></a>
    </div>
  </div>
</header>
