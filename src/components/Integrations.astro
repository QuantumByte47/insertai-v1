---
const systems = [
  {
    tag: "SaaS Platform",
    img: "/assets/generated/work-lumen.webp",
    problem: "A founder needed a market-ready, multi-tenant product — fast.",
    system: "Full multi-tenant SaaS: auth, billing, AI features and an admin layer, built from scratch.",
    tools: ["Next.js", "Postgres", "Stripe", "LLM"],
    outcome: "Launched to market in a single engagement.",
  },
  {
    tag: "Voice AI System",
    img: "/assets/generated/work-verve.webp",
    problem: "Inbound calls overwhelmed the team, especially after hours.",
    system: "Natural-language voice agent wired directly into the client's CRM and scheduling.",
    tools: ["Twilio", "LLM", "CRM API"],
    outcome: "24/7 inbound handled — zero missed calls.",
  },
  {
    tag: "RAG Knowledge Assistant",
    img: "/assets/generated/work-orion.webp",
    problem: "Staff couldn't find answers buried across thousands of documents.",
    system: "Retrieval engine over enterprise docs returning sourced, accurate answers.",
    tools: ["Vector DB", "Embeddings", "LLM"],
    outcome: "Accurate answers across 1000s of documents.",
  },
  {
    tag: "Automation Infrastructure",
    img: "/assets/generated/service-v3-business-automation.webp",
    problem: "Manual data entry sprawled across CRMs, ERPs and 200+ tools.",
    system: "Event-driven workflows that move data, assign tasks and trigger actions automatically.",
    tools: ["Make", "APIs", "Webhooks"],
    outcome: "20–70% reduction in manual operations.",
  },
];
---

<section id="work" class="py-5">
  <div class="site-shell">
    <div class="flex flex-wrap items-end justify-between gap-5 pb-10">
      <div class="max-w-2xl">
        <p class="mono text-[--color-acc]">Case studies</p>
        <h2 class="display mt-4 text-[clamp(2rem,4vw,3.2rem)]">Selected systems <span class="accent">we've built.</span></h2>
      </div>
      <a href="#process" class="inline-flex border-b border-[--color-acc] pb-1 text-sm font-semibold text-[--color-acc-2]">See how we work →</a>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {systems.map((s) => (
        <article class="soft-card group flex flex-col overflow-hidden transition duration-300 hover:-translate-y-1 hover:border-[--color-acc]/40">
          <div class="relative h-44 overflow-hidden">
            <img src={s.img} alt="" loading="lazy" decoding="async" class="h-full w-full object-cover opacity-88 transition duration-500 group-hover:scale-105" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/25 to-transparent"></div>
            <div class="absolute left-5 top-4 text-xs font-bold uppercase tracking-[0.16em] text-[--color-acc-2]">{s.tag}</div>
          </div>

          <div class="flex flex-1 flex-col gap-4 p-6">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <p class="mono text-[10px] text-[--color-fg-dim]">Problem</p>
                <p class="mt-1.5 text-sm leading-6 text-white/62">{s.problem}</p>
              </div>
              <div>
                <p class="mono text-[10px] text-[--color-fg-dim]">System built</p>
                <p class="mt-1.5 text-sm leading-6 text-white/62">{s.system}</p>
              </div>
            </div>

            <div>
              <p class="mono text-[10px] text-[--color-fg-dim]">Tools used</p>
              <div class="mt-2 flex flex-wrap gap-2">
                {s.tools.map((t) => (
                  <span class="rounded-full border border-white/12 bg-white/[0.03] px-2.5 py-1 text-[11px] text-white/70">{t}</span>
                ))}
              </div>
            </div>

            <div class="mt-auto border-t border-white/8 pt-4">
              <p class="mono text-[10px] text-[--color-acc]">Outcome</p>
              <p class="mt-1.5 text-[15px] font-semibold leading-6 text-white">{s.outcome}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
    <p class="mt-6 text-center text-xs text-white/40">Representative systems — named case studies added with approved client assets.</p>
  </div>
</section>
