---
import Reviews from "./Reviews.astro";

const stats = [
  { value: "135+", label: "Workflows automated" },
  { value: "20+", label: "Industries served" },
  { value: "60%", label: "Less manual work (selected workflows)" },
];

const miniOutcomes = [
  { stat: "24/7", text: "Voice AI handling inbound with zero missed calls." },
  { stat: "1000s", text: "Documents made instantly searchable via RAG." },
];

const compare = [
  { who: "Freelancers", build: "build tasks." },
  { who: "Software houses", build: "build apps." },
  { who: "InsertAI", build: "builds AI-powered business systems.", highlight: true },
];
---

<section id="about" class="py-5">
  <div class="site-shell">
    <div class="max-w-2xl pb-10">
      <p class="mono text-[--color-acc]">Real impact</p>
      <h2 class="display mt-4 text-[clamp(2rem,4vw,3.35rem)]">Proof that goes beyond <span class="accent">pretty demos.</span></h2>
    </div>

    <!-- headline metrics -->
    <div class="grid gap-4 sm:grid-cols-3">
      {stats.map((stat) => (
        <div class="soft-card p-7">
          <p class="display text-[clamp(2.2rem,4vw,3rem)] text-white">{stat.value}</p>
          <p class="mt-2 text-sm leading-5 text-white/55">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- quote + mini case outcomes -->
    <div class="mt-4 grid gap-4 lg:grid-cols-[1.35fr_1fr]">
      <Reviews />

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
        {miniOutcomes.map((o) => (
          <div class="soft-card flex items-center gap-5 p-6">
            <span class="display text-3xl text-[--color-acc-2]">{o.stat}</span>
            <p class="text-sm leading-6 text-white/62">{o.text}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- why us vs others -->
    <div class="mt-4 soft-card p-8">
      <h3 class="display text-[clamp(1.4rem,2.6vw,2rem)] text-white">
        Not just workflows. Not just apps. <span class="accent">Complete AI systems.</span>
      </h3>
      <div class="mt-6 grid gap-4 sm:grid-cols-3">
        {compare.map((c) => (
          <div class={`rounded-xl border p-5 ${c.highlight ? "border-[--color-acc]/45 bg-[linear-gradient(150deg,rgba(103,92,255,.14),rgba(11,16,32,.5))]" : "border-white/10 bg-white/[0.02]"}`}>
            <p class={`text-base font-semibold ${c.highlight ? "text-[--color-acc-2]" : "text-white"}`}>{c.who}</p>
            <p class="mt-1 text-sm leading-6 text-white/60">{c.build}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
