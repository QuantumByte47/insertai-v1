---
import { site } from "../data/site";
---

<section id="insights" class="py-5">
  <div class="site-shell">
    <div class="relative overflow-hidden rounded-2xl border border-white/14 bg-[linear-gradient(120deg,rgba(27,47,151,.9),rgba(40,96,255,.82)_42%,rgba(143,50,222,.92))] px-6 py-9 shadow-[0_28px_90px_rgba(74,84,255,.28)] sm:px-10">
      <div class="absolute inset-0 opacity-42 mix-blend-screen" style="background-image:url('/assets/generated/liquid-glass.webp');background-size:cover;background-position:center;"></div>
      <div class="relative grid items-center gap-6 lg:grid-cols-[1fr_0.9fr_auto]">
        <div>
          <p class="mono text-white/65">Ready to build</p>
          <h2 class="display mt-3 text-[clamp(2rem,4vw,3.5rem)] text-white">Let's build your AI operating system.</h2>
        </div>
        <p class="max-w-md text-sm leading-6 text-white/76">
          Bring us your workflow, product idea, or operational bottleneck. We'll help you turn it
          into an AI-powered system, automation layer, or custom app.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href={site.bookingUrl} class="btn-primary bg-white/10 px-6 py-3.5">Book a Strategy Call <span aria-hidden="true">→</span></a>
          <a href={`mailto:${site.email}?subject=My%20workflow`} class="btn-ghost px-6 py-3.5">Send Us Your Workflow</a>
        </div>
      </div>
    </div>
  </div>
</section>
