---
const steps = [
  {
    num: "01",
    icon: "/assets/generated/process-icon-audit-mark.png",
    title: "Audit",
    desc: "We map your systems, data, and the highest-leverage automation opportunities.",
  },
  {
    num: "02",
    icon: "/assets/generated/process-icon-architecture-mark.png",
    title: "System Architecture",
    desc: "We design the stack, data model, and integration points before any code.",
  },
  {
    num: "03",
    icon: "/assets/generated/process-icon-build-mark.png",
    title: "Build Sprint",
    desc: "We engineer production-grade systems in tight, reviewable sprints.",
  },
  {
    num: "04",
    icon: "/assets/generated/process-icon-qa-mark.png",
    title: "QA & Edge Cases",
    desc: "We validate, harden, and stress-test every path and edge case.",
  },
  {
    num: "05",
    icon: "/assets/generated/process-icon-deployment-mark.png",
    title: "Deployment & Iteration",
    desc: "We ship, integrate, monitor, and keep improving in production.",
  },
];
---

<section id="process" class="py-5">
  <div class="site-shell">
    <div class="max-w-2xl pb-12">
      <p class="mono text-[--color-acc]">How we work</p>
      <h2 class="display mt-4 text-[clamp(2rem,4vw,3.2rem)]">A disciplined engineering <span class="accent">process.</span></h2>
    </div>

    <div class="relative">
      <div class="absolute inset-x-10 top-10 hidden h-px bg-gradient-to-r from-[--color-acc]/55 via-[--color-acc]/25 to-transparent xl:block" aria-hidden="true"></div>
      <div class="grid gap-x-6 gap-y-10 sm:grid-cols-2 xl:grid-cols-5">
        {steps.map((step) => (
          <div class="relative">
            <span class="relative z-10 grid h-20 w-20 place-items-center rounded-2xl border border-[--color-acc]/45 bg-[--color-ink] shadow-[0_0_0_7px_var(--color-ink)]">
              <img src={step.icon} alt="" width="512" height="512" loading="lazy" decoding="async" class="h-16 w-16 object-contain" />
            </span>
            <p class="mono mt-6 text-[--color-acc]">{step.num}</p>
            <h3 class="display mt-2 text-lg text-white">{step.title}</h3>
            <p class="mt-2 max-w-[230px] text-sm leading-6 text-white/55">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
