---
const faqs = [
  { q: "How fast can we go live?", a: "Most clients have their first automation or voice agent live within 14 days of the strategy call. Larger multi-system builds roll out in phases so you see value early." },
  { q: "Do your AI voice agents really sound human?", a: "Yes. They use the latest conversational voice models with natural pacing and interruption handling. Most callers can't tell - and they book, qualify, and route like a great receptionist would." },
  { q: "Will this work with QuickBooks and HubSpot?", a: "Absolutely. QuickBooks, HubSpot, Stripe, Xero and 200+ apps are core to what we do. If a tool has an API, we can connect it - and we build custom connectors when one doesn't exist." },
  { q: "Is my data secure?", a: "We follow least-privilege access, encrypt data in transit, and monitor every workflow 24/7. We're happy to sign an NDA and work within your compliance requirements." },
  { q: "What does it cost?", a: "It depends on scope, but we price around ROI - most automations pay for themselves within a month or two. You get a clear, fixed quote after the free strategy call. No surprises." },
  { q: "Do I need technical knowledge?", a: "None. It's fully done-for-you. We handle building, integrating, testing, and monitoring - you just tell us what's eating your team's time." },
];
---

<section id="faq" class="hair-t bg-[--color-ink-soft]">
  <div class="mx-auto max-w-[1600px] px-5 sm:px-8">
    <!-- header -->
    <div class="hair-b grid grid-cols-1 gap-4 py-12 lg:grid-cols-12">
      <p class="mono text-[--color-fg-dim] lg:col-span-3">(06) / FAQ</p>
      <h2 class="display text-[clamp(2rem,5.2vw,4.75rem)] text-[--color-fg] lg:col-span-9">
        Questions, <span class="stroke-type stroke-acc">answered</span>
      </h2>
    </div>

    <!-- accordion -->
    <div>
      {faqs.map((f, i) => (
        <details class="hair-b group border-[--color-line] [&_summary]:list-none">
          <summary class="grid cursor-pointer grid-cols-1 items-start gap-3 py-6 lg:grid-cols-12">
            <span class="mono text-[--color-fg-dim] lg:col-span-3">0{i + 1}</span>
            <span class="display flex items-center justify-between gap-4 text-xl text-[--color-fg] lg:col-span-9">
              {f.q}
              <span class="text-[--color-acc] transition-transform duration-300 group-open:rotate-45">+</span>
            </span>
          </summary>
          <div class="grid grid-cols-1 pb-6 lg:grid-cols-12">
            <p class="leading-relaxed text-[--color-fg-muted] lg:col-span-9 lg:col-start-4">{f.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
