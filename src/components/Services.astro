---
import { site } from "../data/site";

// Spotlight image already includes its own labelled callouts (baked in).
const spotlightImage = "/assets/generated/service-platform-spotlight.webp";

const capabilities = [
  { title: "AI Voice Agents", desc: "Inbound & outbound calls, wired to your CRM.",
    icon: `<rect x="9" y="2.5" width="6" height="11" rx="3"/><path d="M5 11a7 7 0 0 0 14 0"/><path d="M12 18v3.5"/>` },
  { title: "AI Chat Agents", desc: "Support & sales chat that qualifies and acts.",
    icon: `<path d="M4 5h16v11H9l-4 3.5V16H4V5z"/><path d="M8.5 10h0M12 10h0M15.5 10h0"/>` },
  { title: "CRM Automations", desc: "Scoring, routing and follow-ups on autopilot.",
    icon: `<path d="M4.5 12a7.5 7.5 0 0 1 12.5-5.6L20 9"/><path d="M20 4v5h-5"/><path d="M19.5 12a7.5 7.5 0 0 1-12.5 5.6L4 15"/><path d="M4 20v-5h5"/>` },
  { title: "Internal Dashboards", desc: "Live metrics and controls for your team.",
    icon: `<rect x="3" y="3.5" width="18" height="17" rx="2"/><path d="M7 16v-4M12 16V8M17 16v-6"/>` },
  { title: "Custom Web Apps", desc: "Bespoke portals built around your logic.",
    icon: `<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 8.5h18"/><path d="M10 13l-2 2 2 2M14 13l2 2-2 2"/>` },
  { title: "SaaS Platforms", desc: "Multi-tenant products, built to scale.",
    icon: `<path d="M12 3 3 7.5l9 4.5 9-4.5L12 3z"/><path d="M3 12l9 4.5L21 12"/><path d="M3 16.5 12 21l9-4.5"/>` },
  { title: "RAG Knowledge Systems", desc: "Sourced answers over your documents.",
    icon: `<path d="M5 4.5A1.5 1.5 0 0 1 6.5 3H19v14H6.5A1.5 1.5 0 0 0 5 18.5V4.5z"/><path d="M5 18.5A1.5 1.5 0 0 1 6.5 17H19v4H6.5A1.5 1.5 0 0 1 5 19.5"/><path d="M9 8h6M9 11h4"/>` },
  { title: "Workflow Integrations", desc: "Connect 200+ tools into one flow.",
    icon: `<circle cx="6" cy="6" r="2.2"/><circle cx="18" cy="6" r="2.2"/><circle cx="12" cy="18" r="2.2"/><path d="M6 8.2V11a3 3 0 0 0 3 3h1.2M18 8.2V11a3 3 0 0 1-3 3h-1.2"/>` },
];
---

<section id="services" class="py-5">
  <div class="site-shell">
    <div class="grid items-center gap-5 lg:grid-cols-[0.92fr_1.08fr] lg:gap-10">
      <!-- statement (left) -->
      <div class="reveal flex flex-col justify-center px-1 py-6 lg:px-5">
        <p class="mono text-[--color-acc]">What we build</p>
        <h2 class="display mt-4 text-[clamp(2rem,4vw,3.35rem)]">
          From a single agent to an entire <span class="accent">platform</span>.
        </h2>
        <p class="mt-6 max-w-xl text-base leading-7 text-[--color-fg-muted]">
          From AI agents and voice systems to business automation, custom software and SaaS
          platforms — we design and engineer the complex technology growing businesses rely on.
          If you can describe it, we can build it.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={site.bookingUrl} class="btn-primary px-6 py-3.5">Start building <span aria-hidden="true">→</span></a>
          <a href="#work" class="btn-ghost px-6 py-3.5">Explore all 15 services</a>
        </div>
      </div>

      <!-- labelled capability image (right) -->
      <div class="reveal relative">
        <!-- ambient glow bleeding behind the image -->
        <div class="pointer-events-none absolute -inset-6 -z-10 bg-[radial-gradient(circle_at_38%_40%,rgba(46,214,255,.22),transparent_62%),radial-gradient(circle_at_64%_74%,rgba(103,92,255,.2),transparent_60%)] blur-2xl"></div>

        <img
          src={spotlightImage}
          alt="AI engineering capabilities — AI Agents, AI Voice Agents, Business Automation, Custom Software, SaaS Platforms and AI solutions that scale"
          width="1268"
          height="1240"
          loading="lazy"
          decoding="async"
          class="relative w-full rounded-[24px]"
        />
      </div>
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {capabilities.map((c, i) => (
        <article class="cap-card">
          <span class="cap-index">{String(i + 1).padStart(2, "0")}</span>
          <span class="cap-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon}></svg>
          </span>
          <h3 class="cap-title">
            {c.title}
            <svg class="cap-arrow" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </h3>
          <p class="cap-desc">{c.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cap-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    border-radius: 18px;
    padding: 1.55rem 1.5rem 1.6rem;
    border: 1px solid var(--color-line);
    background:
      radial-gradient(120% 90% at 100% 0%, rgba(46, 214, 255, 0.06), transparent 55%),
      linear-gradient(158deg, rgba(19, 25, 50, 0.66), rgba(6, 9, 20, 0.72));
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.4s ease, box-shadow 0.4s ease;
  }

  /* glow blob that blooms on hover */
  .cap-card::before {
    content: "";
    position: absolute;
    z-index: -1;
    top: -55%;
    right: -35%;
    width: 80%;
    height: 130%;
    background: radial-gradient(circle, rgba(46, 214, 255, 0.22), rgba(103, 92, 255, 0.12) 45%, transparent 68%);
    opacity: 0;
    transition: opacity 0.45s ease;
  }

  /* animated top hairline */
  .cap-card::after {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-acc-2), var(--color-acc-3), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cap-card:hover {
    transform: translateY(-6px);
    border-color: rgba(46, 214, 255, 0.42);
    box-shadow: 0 26px 60px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(46, 214, 255, 0.12);
  }
  .cap-card:hover::before { opacity: 1; }
  .cap-card:hover::after { transform: scaleX(1); }

  .cap-index {
    position: absolute;
    top: 1.2rem;
    right: 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: var(--color-fg-dim);
    transition: color 0.4s ease;
  }
  .cap-card:hover .cap-index { color: var(--color-acc-2); }

  .cap-icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 13px;
    color: var(--color-acc-2);
    background: linear-gradient(135deg, rgba(103, 92, 255, 0.28), rgba(30, 214, 255, 0.16));
    border: 1px solid rgba(46, 214, 255, 0.24);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
  }
  .cap-card:hover .cap-icon {
    transform: scale(1.08) rotate(-3deg);
    box-shadow: 0 0 24px rgba(46, 214, 255, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.16);
  }

  .cap-title {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 1.15rem;
    font-size: 15.5px;
    font-weight: 650;
    color: var(--color-fg);
  }

  .cap-arrow {
    color: var(--color-acc-2);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.35s ease, transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .cap-card:hover .cap-arrow { opacity: 1; transform: translateX(0); }

  .cap-desc {
    margin-top: 0.5rem;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--color-fg-muted);
  }

  @media (prefers-reduced-motion: reduce) {
    .cap-card,
    .cap-card::after,
    .cap-icon,
    .cap-arrow { transition: none; }
    .cap-card:hover { transform: none; }
  }
</style>
